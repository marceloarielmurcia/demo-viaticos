<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Solicitud de Viaje - Demo</title>
<style>
  :root {
    --azul: #1F6091;
    --azul-oscuro: #154d75;
    --verde: #4CAF50;
    --verde-oscuro: #3d8b40;
    --gris-bg: #f5f7fa;
    --gris-borde: #d0d7de;
    --texto: #1f2937;
  }
  * { box-sizing: border-box; }
  body {
    font-family: 'Segoe UI', Tahoma, sans-serif;
    background: var(--gris-bg);
    color: var(--texto);
    margin: 0;
    padding: 24px;
  }
  .container {
    max-width: 1200px;
    margin: 0 auto;
    background: #fff;
    border-radius: 12px;
    box-shadow: 0 4px 16px rgba(0,0,0,0.06);
    padding: 28px 32px;
  }
  h1 {
    margin: 0 0 24px;
    font-size: 22px;
    color: var(--azul-oscuro);
    border-bottom: 2px solid var(--azul);
    padding-bottom: 8px;
  }
  .seccion {
    margin-bottom: 28px;
    padding: 18px;
    border: 1px solid var(--gris-borde);
    border-radius: 10px;
    background: #fafbfc;
  }
  .seccion h2 {
    font-size: 16px;
    margin: 0 0 16px;
    color: var(--azul-oscuro);
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }
  .fila {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
  }
  .campo {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .label-azul {
    background: var(--azul);
    color: #fff;
    padding: 8px 12px;
    border-radius: 6px;
    font-size: 13px;
    font-weight: 600;
    text-align: center;
    min-height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  input[type="text"],
  input[type="number"],
  input[type="file"],
  select {
    padding: 8px 10px;
    border: 1px solid var(--gris-borde);
    border-radius: 6px;
    font-size: 14px;
    background: #fff;
    transition: border-color 0.15s;
  }
  input:focus, select:focus {
    outline: none;
    border-color: var(--azul);
    box-shadow: 0 0 0 2px rgba(31,96,145,0.15);
  }
  input[type="file"] { padding: 5px; }
  .acciones {
    display: flex;
    justify-content: flex-end;
    margin-top: 8px;
  }
  .btn-enviar {
    background: var(--verde);
    color: #fff;
    border: none;
    padding: 12px 32px;
    border-radius: 8px;
    font-size: 15px;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.15s;
    box-shadow: 0 2px 6px rgba(76,175,80,0.3);
  }
  .btn-enviar:hover { background: var(--verde-oscuro); }
  .resumen {
    margin-top: 20px;
    padding: 16px;
    background: #eef6ff;
    border-left: 4px solid var(--azul);
    border-radius: 6px;
    font-size: 13px;
    white-space: pre-wrap;
    display: none;
  }
  @media (max-width: 768px) {
    .fila { grid-template-columns: 1fr; }
  }
</style>
</head>
<body>
<div class="container">
  <h1>🧳 Solicitud de Viaje</h1>

  <form id="formViaje">

    <!-- ================== BUS ================== -->
    <div class="seccion">
      <h2>🚌 Bus</h2>
      <div class="fila">
        <div class="campo">
          <div class="label-azul">Adjuntar Pasaje</div>
          <input type="file" name="bus_pasaje" accept=".pdf,.jpg,.png" />
        </div>
        <div class="campo">
          <div class="label-azul">Empresa</div>
          <input type="text" name="bus_empresa" placeholder="Ej: Andesmar" />
        </div>
        <div class="campo">
          <div class="label-azul">Costo</div>
          <input type="number" step="0.01" name="bus_costo" placeholder="0.00" />
        </div>
        <div class="campo">
          <div class="label-azul">Forma de Pago</div>
          <select name="bus_pago">
            <option value="">-- Seleccionar --</option>
            <option>TC Federico</option>
            <option>TC Tejerina</option>
            <option>Completar</option>
          </select>
        </div>
      </div>
    </div>

    <!-- ================== AÉREO ================== -->
    <div class="seccion">
      <h2>✈️ Aéreo</h2>
      <div class="fila">
        <div class="campo">
          <div class="label-azul">Código de Reserva</div>
          <input type="text" name="aer_codigo" placeholder="Ej: ABC123" />
        </div>
        <div class="campo">
          <div class="label-azul">Aerolínea</div>
          <input type="text" name="aer_aerolinea" placeholder="Ej: Aerolíneas Argentinas" />
        </div>
        <div class="campo">
          <div class="label-azul">Costo</div>
          <input type="number" step="0.01" name="aer_costo" placeholder="0.00" />
        </div>
        <div class="campo">
          <div class="label-azul">Forma de Pago</div>
          <select name="aer_pago">
            <option value="">-- Seleccionar --</option>
            <option>TC Federico</option>
            <option>TC Tejerina</option>
            <option>Completar</option>
          </select>
        </div>
      </div>
    </div>

    <!-- ================== ALOJAMIENTO ================== -->
    <div class="seccion">
      <h2>🏨 Alojamiento</h2>
      <div class="fila">
        <div class="campo">
          <div class="label-azul">Hotel</div>
          <input type="text" name="alo_hotel" placeholder="Ej: Hotel Sheraton" />
        </div>
        <div class="campo" style="visibility:hidden;"></div>
        <div class="campo">
          <div class="label-azul">Costo</div>
          <input type="number" step="0.01" name="alo_costo" placeholder="0.00" />
        </div>
        <div class="campo">
          <div class="label-azul">Forma de Pago</div>
          <select name="alo_pago">
            <option value="">-- Seleccionar --</option>
            <option>TC Federico</option>
            <option>TC Tejerina</option>
            <option>Completar</option>
          </select>
        </div>
      </div>
    </div>

    <div class="acciones">
      <button type="submit" class="btn-enviar">✉️ Enviar</button>
    </div>

    <div id="resumen" class="resumen"></div>
  </form>
</div>

<script>
  const form = document.getElementById('formViaje');
  const resumen = document.getElementById('resumen');

  form.addEventListener('submit', function(e) {
    e.preventDefault();
    const data = new FormData(form);
    let texto = '✅ SOLICITUD ENVIADA\n\n';

    texto += '🚌 BUS\n';
    texto += `   • Pasaje adjunto: ${data.get('bus_pasaje')?.name || '—'}\n`;
    texto += `   • Empresa: ${data.get('bus_empresa') || '—'}\n`;
    texto += `   • Costo: $${data.get('bus_costo') || '0.00'}\n`;
    texto += `   • Forma de Pago: ${data.get('bus_pago') || '—'}\n\n`;

    texto += '✈️ AÉREO\n';
    texto += `   • Código de Reserva: ${data.get('aer_codigo') || '—'}\n`;
    texto += `   • Aerolínea: ${data.get('aer_aerolinea') || '—'}\n`;
    texto += `   • Costo: $${data.get('aer_costo') || '0.00'}\n`;
    texto += `   • Forma de Pago: ${data.get('aer_pago') || '—'}\n\n`;

    texto += '🏨 ALOJAMIENTO\n';
    texto += `   • Hotel: ${data.get('alo_hotel') || '—'}\n`;
    texto += `   • Costo: $${data.get('alo_costo') || '0.00'}\n`;
    texto += `   • Forma de Pago: ${data.get('alo_pago') || '—'}\n`;

    resumen.textContent = texto;
    resumen.style.display = 'block';
    resumen.scrollIntoView({ behavior: 'smooth' });
  });
</script>
</body>
</html>
